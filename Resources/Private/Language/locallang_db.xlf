		<body>
			<trans-unit id="be_groups.tx_begroupsroles_title">
				<source>Backend group roles</source>
			</trans-unit>
			<trans-unit id="be_groups.tx_begroupsroles_isrole">
				<source>Use this group as role</source>
			</trans-unit>
			<trans-unit id="be_groups.tx_begroupsroles_isrole.description">
				<source>Adds this groups to the list of roles the user can take on.</source>
			</trans-unit>
			<trans-unit id="be_users.tx_begroupsroles_title">
				<source>Backend user roles</source>
			</trans-unit>
			<trans-unit id="be_users.tx_begroupsroles_enabled">
				<source>Use groups as roles</source>
			</trans-unit>
			<trans-unit id="be_users.tx_begroupsroles_enabled.description">
				<source>Adds a selector in the toolbar, enabling the user to switch group (role).</source>
			</trans-unit>
			<trans-unit id="be_users.tx_begroupsroles_limit">
				<source>Restrict to one group</source>
			</trans-unit>
			<trans-unit id="be_users.tx_begroupsroles_limit.description">
				<source>Ensures only one group of the defined ones can be used simultaneously. Otherwise, the user can choose to take on all roles. On login the first group is used as default.</source>
			</trans-unit>
